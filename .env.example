# Syncro PMS Environment Configuration
# Copy this file to .env and configure your values

# Database Configuration
DB_HOST=localhost
DB_NAME=syncro
DB_USER=root
DB_PASS=

# Application Settings
APP_ENV=production
APP_URL=http://localhost/syncro
APP_DEBUG=false

# Session Configuration
SESSION_NAME=syncro_session
SESSION_LIFETIME=28800 # 8 hours

# Security Settings
# Generate a random 32-character string for CSRF
CSRF_SECRET=CHANGE_ME_IN_PRODUCTION
# Generate a 32-byte (64 char hex) key for encryption
APP_KEY=CHANGE_ME_IN_PRODUCTION

# Stripe API Keys
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin Default Credentials (set during installation)
ADMIN_DEFAULT_EMAIL=admin@syncro.com
ADMIN_DEFAULT_PASSWORD=admin

# Email (SMTP) Configuration
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@syncro.com
MAIL_FROM_NAME="Syncro PMS"
