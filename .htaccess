<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Block access to sensitive files and directories
<FilesMatch "^\.env">
    Require all denied
    Order allow,deny
    Deny from all
</FilesMatch>

<DirectoryMatch "^core">
    Require all denied
    Order allow,deny
    Deny from all
</DirectoryMatch>